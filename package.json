{
  "name": "authority-arc",
  "version": "0.1.0",
  "private": true,
  "description": "A learning path through library identity — identifier resolution, authority disambiguation, classification, entity connections, and metadata change tracking, taught through OCLC and VIAF APIs.",
  "author": "Paul Clark <paul@systemslibrarian.dev>",
  "license": "CC-BY-NC-SA-4.0",
  "homepage": "https://authorityarc.systemslibrarian.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/systemslibrarian/authority-arc"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fixtures:refresh": "node scripts/refresh-fixtures.mjs",
    "fixtures:verify": "node scripts/verify-fixtures.mjs"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitest/coverage-v8": "^3.1.4",
    "autoprefixer": "10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "happy-dom": "^17.4.4",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.3",
    "vitest": "^3.1.4"
  }
}
