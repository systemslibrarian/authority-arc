# Authority Arc — environment variables
#
# Copy this file to .env.local for development. NEVER commit .env.local.
#
# ──────────────────────────────────────────────────────────────────────────
# VIAF API (free, no key required)
# ──────────────────────────────────────────────────────────────────────────
# VIAF is the default data source for Authority Arc. No credentials needed.
# The proxy at /api/resolve calls https://viaf.org directly.
#
# ──────────────────────────────────────────────────────────────────────────
# OCLC WorldCat Entities API (optional, requires Meridian subscription)
# ──────────────────────────────────────────────────────────────────────────
# When set, /api/resolve will additionally call OCLC's PID Lookup endpoint
# and surface the entityMd5 fingerprint and canonical WorldCat Entity URI.
# Until access is provisioned these can remain unset; the site falls back
# to VIAF-only mode automatically.
#
# Request a custom WSKey at:
#   https://platform.worldcat.org/wskey/

OCLC_CLIENT_ID=
OCLC_CLIENT_SECRET=
OCLC_TOKEN_URL=https://oauth.oclc.org/token
OCLC_ENTITIES_BASE_URL=https://entity.api.oclc.org
OCLC_SCOPES=publicEntities:read_brief_entities publicEntities:read_references

# Authorization Code + PKCE (only used by /api/auth/callback if a sign-in
# button is wired in; the CCG flow above does not need these).
OCLC_REDIRECT_URI=https://authority-arc.vercel.app/api/auth/callback
OCLC_AUTHORIZE_URL=https://oauth.oclc.org/auth

# Optional rate-limit override (requests per minute, per IP) for /api/resolve
# Default: 30
# RATE_LIMIT_RPM=30
